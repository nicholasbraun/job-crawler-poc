{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["system", "runtime", "crawler"],
  "templating": {
    "list": []
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "System (runtime & process)",
  "uid": "system",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Memory (heap vs GOMEMLIMIT)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "id": 1,
      "title": "Heap headroom used",
      "description": "Live heap in-use as a percentage of GOMEMLIMIT (go_memstats_heap_inuse_bytes / crawler_runtime_go_memory_limit_bytes). The single number for 'how close to OOM'. Turns red as the heap approaches the soft limit the GC targets (ADR-0033). Uses on() group_left because the collector heap series carries no otel_scope labels while the OTel-emitted limit gauge does.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * go_memstats_heap_inuse_bytes / on() group_left() max(crawler_runtime_go_memory_limit_bytes)",
          "legendFormat": "headroom used",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "title": "Heap in-use",
      "description": "Bytes of heap currently in use by live objects (go_memstats_heap_inuse_bytes).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "heap in-use",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "title": "Resident memory (RSS)",
      "description": "Process resident set size (process_resident_memory_bytes) — the number the container mem_limit and the kernel OOM-killer act on.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes",
          "legendFormat": "rss",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 4,
      "title": "GOMEMLIMIT",
      "description": "The Go soft memory limit (crawler_runtime_go_memory_limit_bytes, via debug.SetMemoryLimit(-1)). Shows ~9.2 EB (math.MaxInt64) when GOMEMLIMIT is unset — set it in the environment for the headroom panels to mean anything (ADR-0033).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "unit": "bytes"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(crawler_runtime_go_memory_limit_bytes)",
          "legendFormat": "GOMEMLIMIT",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "title": "Heap & RSS vs GOMEMLIMIT",
      "description": "The headline OOM panel. Heap in-use, heap allocated, RSS, and the next-GC target plotted against GOMEMLIMIT (the thick red dashed line). An approaching OOM reads as the heap/RSS lines climbing toward the limit line; the gap closing is the warning the robots-cache incident (ADR-0032) had no view of.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true,
            "axisPlacement": "auto"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "GOMEMLIMIT" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineWidth", "value": 2 },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "next-GC target" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [4, 6] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(crawler_runtime_go_memory_limit_bytes)",
          "legendFormat": "GOMEMLIMIT",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_resident_memory_bytes",
          "legendFormat": "RSS",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_memstats_heap_inuse_bytes",
          "legendFormat": "heap in-use",
          "refId": "C"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_memstats_heap_alloc_bytes",
          "legendFormat": "heap allocated",
          "refId": "D"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_memstats_next_gc_bytes",
          "legendFormat": "next-GC target",
          "refId": "E"
        }
      ]
    },
    {
      "type": "row",
      "id": 101,
      "title": "Goroutines & GC",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "id": 6,
      "title": "Goroutines",
      "description": "Live goroutines (go_goroutines). Unbounded growth is the other classic pre-OOM tell — a goroutine leak holds every frame and captured variable live, which the GC cannot reclaim.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max", "lastNotNull"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_goroutines",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 7,
      "title": "GC pause quantiles",
      "description": "Stop-the-world GC pause durations by quantile (go_gc_duration_seconds summary). A rising p1 (worst-case) pause under a growing heap signals GC pressure.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 5,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "go_gc_duration_seconds",
          "legendFormat": "q{{quantile}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 8,
      "title": "GC frequency",
      "description": "Completed GC cycles per second (rate of go_gc_duration_seconds_count). Climbs as the allocation rate rises or the heap approaches GOMEMLIMIT and the GC runs harder to stay under it.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(go_gc_duration_seconds_count[$__rate_interval])",
          "legendFormat": "GC/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "id": 102,
      "title": "CPU & process",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "type": "timeseries",
      "id": 9,
      "title": "CPU usage (cores)",
      "description": "CPU cores consumed (rate of process_cpu_seconds_total). 1.0 means one full core; compare against the container's CPU allotment.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(process_cpu_seconds_total[$__rate_interval])",
          "legendFormat": "cores",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 10,
      "title": "Open file descriptors (vs max)",
      "description": "Open FDs (process_open_fds) against the process limit (process_max_fds, red dashed). FDs climbing toward the ceiling is a socket/file leak — connections or bodies not closed.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 10,
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max fds" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["max", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_open_fds",
          "legendFormat": "open fds",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_max_fds",
          "legendFormat": "max fds",
          "refId": "B"
        }
      ]
    }
  ]
}
