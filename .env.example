# .env.example -- copy to `.env` and adjust. The app runs without a .env at all;
# every value below is the code's built-in default except LLM_API_KEY (needed for
# the LLM classifier/extractor). This file is loaded two ways:
#   1. Local `go run ./cmd/server` reads it via godotenv.
#   2. `docker compose up` substitutes ${VAR} references in docker-compose.yml from
#      it (the LLM_*, CRAWL_MAX_WORKERS, and LOG_LEVEL knobs).
# Note: in Docker, DATABASE_URL and REDIS_ADDR are set to the compose service names
# directly and IGNORE the values here -- the localhost defaults below apply to local
# `go run` only.

# --- Datastores (local `go run`; Docker overrides with service names) ---
DATABASE_URL=postgres://crawler:crawler@localhost:5432/crawler?sslmode=disable
REDIS_ADDR=localhost:6379

# --- LLM classifier / extractor (OpenAI-compatible chat-completions API) ---
# LLM_API_KEY is required for the career-page classifier + job-listing extractor.
# Leave BASE_URL/MODEL at the OpenRouter defaults, or point them at a local server
# (e.g. Ollama). Locally prefer a non-reasoning instruct model -- a reasoning model
# spends a hidden think phase the crawler discards.
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1/chat/completions
LLM_MODEL=openai/gpt-5.4-nano
# A long per-request timeout and few workers suit a serial local model; raise both
# for a fast, highly-parallel cloud API. LLM_MAX_WORKERS sizes the durable LLM
# stage's consumer group (goroutines draining the per-run Redis Stream), not an
# in-process pool.
LLM_TIMEOUT=5m
LLM_MAX_WORKERS=2
# Cap the page text sent to each LLM call, keeping a local model fast.
LLM_CLASSIFY_MAX_CHARS=1500
LLM_EXTRACT_MAX_CHARS=8000

# --- Crawl ---
# Per-run crawl worker pools (discovery + url/keyword). Crawl workers are I/O-bound,
# so this can be raised well past the default once the frontier is no longer the
# bottleneck; watch the Postgres pool and outbound network next.
CRAWL_MAX_WORKERS=50
# Per-run ceiling on the visited ZSET's cardinality (ADR-0027 / #75).
CRAWL_VISITED_CAP=5000000

# --- robots.txt cache (ADR-0032) ---
# How many hosts' parsed rules are held, and for how long before a re-fetch, so the
# shared cache cannot grow without limit across a discovery crawl that touches tens
# of thousands of hosts.
ROBOTS_CACHE_SIZE=16384
ROBOTS_CACHE_TTL=1h

# --- Logging ---
# One of DEBUG, INFO, WARN, ERROR.
LOG_LEVEL=INFO

# --- Go runtime (optional; docker-compose sets this for the container) ---
# Soft heap ceiling Go's GC respects. The crawler container sets GOMEMLIMIT=1700MiB
# (sized to its 2g mem_limit) in docker-compose.yml. Leave it unset for local `go
# run` unless you want to reproduce the container's GC backpressure locally.
# GOMEMLIMIT=1700MiB
