.DS_Store
.env
.*.env

# Go build output (see Makefile server-build)
/bin/

# Node / Vite
web/node_modules/

# tsc build artifacts (vite reads vite.config.ts directly)
web/*.tsbuildinfo
web/vite.config.js
web/vite.config.d.ts

